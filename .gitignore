# ===== Merath Mobile — Unified .gitignore =====

# Expo
.expo/
dist/
web-build/
expo-env.d.ts
npm-debug.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# Environment Variables
.env
.env.local
.env.*.local

# Node Modules
node_modules/

# Yarn
.yarn/*
!.yarn/cache
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build Outputs
build/
*.tsbuildinfo

# Logs
logs/
*.log

# Temporary Files
*.tmp
.cache/

# EAS Local
.eas/

# Testing
coverage/
.nyc_output/
test-results/
test-reports/

# Binaries
*.apk
*.aab
*.ipa
