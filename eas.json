{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote",
    "packageManager": "npm"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": true,
      "ignorePaths": [".expo"]
    },
    "production": {
      "autoIncrement": true,
      "ignorePaths": [".expo"],
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "env": {
          "EAS_BUILD_COMPRESS": "true"
        }
      },
      "env": {
        "APP_ENV": "production"
      }
    },
    "production-aab": {
      "autoIncrement": true,
      "ignorePaths": [".expo"],
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
