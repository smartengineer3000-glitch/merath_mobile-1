# .easignore - Files to exclude from EAS Build

# Git
.git/
.gitignore

# Node modules - not needed in build
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# IDE and editor
.idea/
.vscode/
.sublime-project
.sublime-workspace
*.swp
*.swo
*~

# OS specific
.DS_Store
Thumbs.db
.env.local

# Build artifacts
build/
dist/
.expo/
.eas/

# Tests
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
test-reports/
coverage/
.nyc_output/

# Development files
.expo-shared/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Documentation and support
*.md
CHANGELOG.md
README.md
support documents/
docs/
scripts/

# Miscellaneous
e2e/config.json
PHASES_*.md
support\\ documents/

# Temporary files
*.tmp
.cache/
