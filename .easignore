# Root .easignore — files to exclude from EAS Build upload

# Documentation
*.md
docs/
scripts/

# Test files
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
test-reports/
test-results/
coverage/
.nyc_output/
vitest.config.ts

# Linting
.eslintrc.js
eslint.config.js

# IDE & OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Dev configs not needed at build time
eas.json
.expo-shared/
package-lock.json

# Logs
npm-debug.log*
*.log

# Temp
*.tmp
.cache/
.eas/
