# .easignore – Files to exclude from EAS Build

# Git metadata
.git/
.gitignore

# Dependencies (EAS reinstalls these fresh)
node_modules/

# IDE & OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Development / Test files
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
test-reports/
coverage/
.nyc_output/

# Local development configs
.expo-shared/
npm-debug.log*
*.log

# Documentation
*.md
CHANGELOG.md
README.md
docs/
scripts/

# Temporary
*.tmp
.cache/
.eas/