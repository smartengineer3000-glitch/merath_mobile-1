# Root .easignore — exclude non-build files from EAS upload

# Git & EAS metadata
.git/
.gitignore
.easignore
.eas/
.expo-shared/

# Documentation & reference
*.md
*.html
docs/
scripts/

# Test files
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
test-reports/
test-results/
coverage/
.nyc_output/
vitest.config.ts

# Linting & formatting
.eslintrc.js
eslint.config.js
.prettierrc*
prettier.config.*

# IDE & OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Dev configs not needed at build time
eas.json
package-lock.json

# Logs
npm-debug.log*
*.log

# Temp & cache
*.tmp
.cache/

# Build outputs (local only)
*.apk
*.aab
*.ipa
